generator client {
  provider = "prisma-client-js"
  output   = "./prisma-client"
}

datasource db {
  provider = "postgresql"
}

model IncidentLog {
  id         String   @id @default(uuid())
  shipmentId String
  raisedById String
  reason     String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  phoneNumber     String           @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            UserRole         @default(CUSTOMER)
  status          IdentityStatus   @default(PENDING_VERIFICATION)
  avatarUrl       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  businessProfile BusinessProfile?
  notifications   Notification[]
  reviewsGiven    Review[]         @relation("CustomerReviews")
  riderProfile    RiderProfile?
  savedAddresses  SavedAddress[]
  shipmentsSent   Shipment[]       @relation("CustomerShipments")
  wallet          Wallet?

  @@map("users")
}

model SavedAddress {
  id         String      @id @default(uuid())
  userId     String
  label      String
  type       AddressType @default(HOME)
  street     String
  city       String
  state      String
  country    String      @default("Nigeria")
  postalCode String?
  latitude   Float
  longitude  Float
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_addresses")
}

model RiderProfile {
  id                  String            @id @default(uuid())
  userId              String            @unique
  nin                 String?           @unique
  driversLicense      String?           @unique
  isOnline            Boolean           @default(false)
  ratingAverage       Float             @default(5.0)
  currentHubId        String?
  activeVehicleId     String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  completedDeliveries Int               @default(0)
  trustScore          Int               @default(100)
  reviewsReceived     Review[]          @relation("RiderReviews")
  assignments         RiderAssignment[]
  activeVehicle       Vehicle?          @relation("ActiveVehicle", fields: [activeVehicleId], references: [id])
  currentHub          TransitHub?       @relation(fields: [currentHubId], references: [id])
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipments           Shipment[]        @relation("RiderShipments")
  ownedVehicles       Vehicle[]         @relation("VehicleOwner")

  @@index([currentHubId])
  @@map("rider_profiles")
}

model Vehicle {
  id              String        @id @default(uuid())
  ownerId         String
  type            VehicleType   @default(MOTORBIKE)
  make            String
  model           String
  year            Int?
  plateNumber     String        @unique
  color           String?
  insuranceExpiry DateTime?
  isVerified      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activeRider     RiderProfile? @relation("ActiveVehicle")
  owner           RiderProfile  @relation("VehicleOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("vehicles")
}

model BusinessProfile {
  id                  String     @id @default(uuid())
  userId              String     @unique
  businessName        String     @unique
  registrationNumber  String?    @unique
  logoUrl             String?
  website             String?
  marketplaceStoreId  String?    @unique
  isMarketplaceVendor Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipments           Shipment[] @relation("BusinessShipments")

  @@map("business_profiles")
}

model TransitHub {
  id           String         @id @default(uuid())
  name         String         @unique
  street       String
  city         String
  state        String
  latitude     Float
  longitude    Float
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  riders       RiderProfile[]
  hubShipments Shipment[]     @relation("HubLocation")

  @@map("transit_hubs")
}

model Shipment {
  id                  String            @id @default(uuid())
  trackingCode        String            @unique
  status              ShipmentStatus    @default(PENDING)
  tier                DeliveryTier      @default(STANDARD)
  pickupAddress       String
  pickupLat           Float
  pickupLng           Float
  recipient           String
  recipientPhone      String
  dropoffAddress      String
  dropoffLat          Float
  dropoffLng          Float
  packageType         String
  packageWeightClass  String
  specialNotes        String?
  isCashCollection    Boolean           @default(false)
  codAmount           Decimal           @default(0.00) @db.Decimal(10, 2)
  isInsured           Boolean           @default(false)
  insurancePremium    Decimal           @default(0.00) @db.Decimal(10, 2)
  isHouseMoving       Boolean           @default(false)
  baseFare            Decimal           @db.Decimal(10, 2)
  distanceFare        Decimal           @db.Decimal(10, 2)
  surgePremium        Decimal           @default(0.00) @db.Decimal(10, 2)
  totalPrice          Decimal           @db.Decimal(10, 2)
  riderShare          Decimal           @db.Decimal(10, 2)
  platformShare       Decimal           @db.Decimal(10, 2)
  customerId          String
  businessId          String?
  riderId             String?
  currentHubId        String?
  marketplaceOrderId  String?           @unique
  promoCodeId         String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  escrowReleaseAt     DateTime?
  isSmartDelivery     Boolean           @default(false)
  smartDeliveryPhotos String[]
  verificationPin     String
  reviews             Review[]
  assignments         RiderAssignment[]
  business            BusinessProfile?  @relation("BusinessShipments", fields: [businessId], references: [id])
  currentHub          TransitHub?       @relation("HubLocation", fields: [currentHubId], references: [id])
  customer            User              @relation("CustomerShipments", fields: [customerId], references: [id])
  promoCode           PromoCode?        @relation(fields: [promoCodeId], references: [id])
  rider               RiderProfile?     @relation("RiderShipments", fields: [riderId], references: [id])
  timelineEvents      StatusTimeline[]
  trackingLogs        TrackingLog[]

  @@index([status])
  @@index([customerId])
  @@index([riderId])
  @@map("shipments")
}

model RiderAssignment {
  id         String           @id @default(uuid())
  shipmentId String
  riderId    String
  status     AssignmentStatus @default(OFFERED)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  rider      RiderProfile     @relation(fields: [riderId], references: [id], onDelete: Cascade)
  shipment   Shipment         @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([riderId])
  @@map("rider_assignments")
}

model TrackingLog {
  id         String   @id @default(uuid())
  shipmentId String
  latitude   Float
  longitude  Float
  bearing    Float?
  createdAt  DateTime @default(now())
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt(sort: Desc)])
  @@map("tracking_logs")
}

model StatusTimeline {
  id          String         @id @default(uuid())
  shipmentId  String
  status      ShipmentStatus
  description String?
  changedBy   String
  createdAt   DateTime       @default(now())
  shipment    Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("status_timelines")
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  balance      Decimal       @default(0.00) @db.Decimal(12, 2)
  currency     String        @default("NGN")
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Transaction {
  id            String          @id @default(uuid())
  walletId      String
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  category      LedgerCategory
  referenceCode String          @unique
  description   String
  createdAt     DateTime        @default(now())
  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("transactions")
}

model PromoCode {
  id           String     @id @default(uuid())
  code         String     @unique
  discount     Decimal    @db.Decimal(10, 2)
  isPercentage Boolean    @default(false)
  expiryDate   DateTime
  usageLimit   Int        @default(100)
  usedCount    Int        @default(0)
  isActive     Boolean    @default(true)
  shipments    Shipment[]

  @@map("promo_codes")
}

model Review {
  id         String       @id @default(uuid())
  shipmentId String
  reviewerId String
  riderId    String
  rating     Int
  comment    String?
  createdAt  DateTime     @default(now())
  reviewer   User         @relation("CustomerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  rider      RiderProfile @relation("RiderReviews", fields: [riderId], references: [id], onDelete: Cascade)
  shipment   Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@map("reviews")
}

model Notification {
  id        String      @id @default(uuid())
  userId    String
  title     String
  body      String
  channel   ChannelType @default(IN_APP)
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model SupportTicket {
  id          String   @id @default(uuid())
  creatorId   String
  subject     String
  description String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_tickets")
}

enum UserRole {
  CUSTOMER
  BUSINESS_OWNER
  RIDER
  ADMIN
  SUPER_ADMIN
}

enum IdentityStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  SUSPENDED
}

enum VehicleType {
  BICYCLE
  MOTORBIKE
  CAR
  MINIVAN
  TRUCK
}

enum AddressType {
  HOME
  OFFICE
  WAREHOUSE
  PICKUP_POINT
}

enum ShipmentStatus {
  PENDING
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  ARRIVED_AT_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  DISPUTED
}

enum DeliveryTier {
  STANDARD
  EXPRESS
  SAME_DAY
  INTERSTATE
}

enum AssignmentStatus {
  OFFERED
  ACCEPTED
  REJECTED
  TIMED_OUT
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum LedgerCategory {
  DELIVERY_PAYMENT
  RIDER_EARNINGS
  PLATFORM_COMMISSION
  WALLET_TOPUP
  WITHDRAWAL
  INSURANCE_PREMIUM
  PROMO_DISCOUNT
  CASH_COLLECTION_REMITTANCE
}

enum ChannelType {
  IN_APP
  PUSH
  SMS
  EMAIL
}
